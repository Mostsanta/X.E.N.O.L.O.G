import torch
import torch.nn as nn
import torch.nn.functional as F

# =========================
# Core Sigma-Reverberation Layer (NO ATTENTION)
# =========================
class SigmaReverbLayer(nn.Module):
    def __init__(self, dim, hidden=128):
        super().__init__()

        # Complex projection
        self.to_complex = nn.Linear(dim, dim * 2)

        # Field evolution (nonlinear)
        self.field_net = nn.Sequential(
            nn.Linear(dim * 2, hidden), nn.Tanh(),
            nn.Linear(hidden, dim * 2)
        )

        # Reverberation memory (R and R2)
        self.memory_R = nn.Parameter(torch.zeros(1, 1, dim, 2))
        self.memory_R2 = nn.Parameter(torch.zeros(1, 1, dim, 2))

        # Learnable coefficients
        self.alpha = nn.Parameter(torch.tensor(0.5))
        self.beta = nn.Parameter(torch.tensor(0.3))
        self.gamma = nn.Parameter(torch.tensor(0.2))

        self.out_proj = nn.Linear(dim * 2, dim)

    def forward(self, x):
        # x: [B, T, D]
        B, T, D = x.shape

        # ---- Complex encoding ----
        c = self.to_complex(x)
        real, imag = c.chunk(2, dim=-1)
        z = torch.complex(real, imag)

        # ---- Global interference field ----
        global_field = z.mean(dim=1, keepdim=True)

        # ---- Convert memory to complex ----
        R = torch.complex(self.memory_R[..., 0], self.memory_R[..., 1])
        R2 = torch.complex(self.memory_R2[..., 0], self.memory_R2[..., 1])

        # Broadcast memory
        R = R.expand(B, T, D)
        R2 = R2.expand(B, T, D)

        # ---- Sigma + Reverberation dynamics ----
        z = z + self.alpha * global_field + self.beta * R + self.gamma * R2

        # ---- Nonlinear evolution ----
        z_real = torch.view_as_real(z).view(B, T, -1)
        z_evolved = self.field_net(z_real)

        r, i = z_evolved.chunk(2, dim=-1)
        z_new = torch.complex(r, i)

        # ---- Update reverberation memory ----
        # R(t+1) = decay * R + mean(z)
        new_R = 0.9 * R.mean(dim=(0,1), keepdim=True) + 0.1 * z_new.mean(dim=(0,1), keepdim=True)
        new_R2 = 0.9 * R2.mean(dim=(0,1), keepdim=True) + 0.1 * (z_new ** 2).mean(dim=(0,1), keepdim=True)

        # Store back (detach to stabilize)
        self.memory_R.data = torch.view_as_real(new_R).detach()
        self.memory_R2.data = torch.view_as_real(new_R2).detach()

        # ---- Interference intensity (implicit reasoning) ----
        intensity = torch.abs(z_new) ** 2

        # ---- Back to real space ----
        out = self.out_proj(torch.cat([z_new.real, z_new.imag], dim=-1))

        return out + x  # residual

# =========================
# Pure Sigma Block
# =========================
class SigmaBlock(nn.Module):
    def __init__(self, dim):
        super().__init__()
        self.sigma = SigmaReverbLayer(dim)
        self.ff = nn.Sequential(
            nn.Linear(dim, dim * 4),
            nn.GELU(),
            nn.Linear(dim * 4, dim)
        )
        self.norm1 = nn.LayerNorm(dim)
        self.norm2 = nn.LayerNorm(dim)

    def forward(self, x):
        x = self.sigma(x)
        x = self.norm1(x)

        x = x + self.ff(x)
        x = self.norm2(x)

        return x

# =========================
# Pure Sigma LLM (NO ATTENTION)
# =========================
class SigmaLLM(nn.Module):
    def __init__(self, vocab_size, dim=128, depth=6):
        super().__init__()
        self.embed = nn.Embedding(vocab_size, dim)
        self.layers = nn.ModuleList([
            SigmaBlock(dim) for _ in range(depth)
        ])
        self.lm_head = nn.Linear(dim, vocab_size)

    def forward(self, input_ids):
        x = self.embed(input_ids)

        for layer in self.layers:
            x = layer(x)

        logits = self.lm_head(x)
        return logits

# =========================
# Example Run
# =========================
if __name__ == "__main__":
    vocab_size = 1000
    model = SigmaLLM(vocab_size, dim=128, depth=4)

    input_ids = torch.randint(0, vocab_size, (2, 16))
    logits = model(input_ids)

    print("Logits:", logits.shape)

    targets = torch.randint(0, vocab_size, (2, 16))
    loss = F.cross_entropy(logits.view(-1, vocab_size), targets.view(-1))

    loss.backward()
    print("Loss:", loss.item())
